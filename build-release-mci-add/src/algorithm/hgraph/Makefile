	cd /root/vsag-hgraph-mci-companion/build-release-mci-add && $(MAKE) $(MAKESILENT) -f src/algorithm/hgraph/CMakeFiles/hgraph.dir/build.make src/algorithm/hgraph/CMakeFiles/hgraph.dir/hgraph_serialize.cpp.o
.PHONY : hgraph_serialize.cpp.o

hgraph_serialize.i: hgraph_serialize.cpp.i
.PHONY : hgraph_serialize.i

# target to preprocess a source file
hgraph_serialize.cpp.i:
	cd /root/vsag-hgraph-mci-companion/build-release-mci-add && $(MAKE) $(MAKESILENT) -f src/algorithm/hgraph/CMakeFiles/hgraph.dir/build.make src/algorithm/hgraph/CMakeFiles/hgraph.dir/hgraph_serialize.cpp.i
.PHONY : hgraph_serialize.cpp.i

hgraph_serialize.s: hgraph_serialize.cpp.s
.PHONY : hgraph_serialize.s

# target to generate assembly for a file
hgraph_serialize.cpp.s:
	cd /root/vsag-hgraph-mci-companion/build-release-mci-add && $(MAKE) $(MAKESILENT) -f src/algorithm/hgraph/CMakeFiles/hgraph.dir/build.make src/algorithm/hgraph/CMakeFiles/hgraph.dir/hgraph_serialize.cpp.s
.PHONY : hgraph_serialize.cpp.s

